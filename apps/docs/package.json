{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vitepress dev --port 8000",
    "build-only": "cross-env NODE_OPTIONS=--max-old-space-size=4096 vitepress build",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vitepress preview",
    "format": "oxfmt src/",
    "lint": "run-s lint:*",
    "lint:eslint": "eslint . --fix --cache",
    "lint:oxlint": "oxlint . --fix",
    "test:lint:eslint": "eslint src tests",
    "test:lint:oxlint": "oxlint src tests",
    "test:lint": "run-s test:lint:eslint test:lint:oxlint",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "test": "run-s test:lint test:unit",
    "test:lint:ci": "pnpm run test:lint",
    "test:ci": "run-s test:lint:ci test:unit:ci"
  },
  "devDependencies": {
    "@iconify-json/bi": "^1.2.7",
    "@iconify-json/logos": "^1.2.10",
    "@stackblitz/sdk": "^1.11.0",
    "@toycode/markdown-it-class": "^1.2.4",
    "@tsconfig/node24": "^24.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "@vueuse/core": "^14.2.1",
    "bootstrap": "^5.3.8",
    "bootstrap-vue-next": "workspace:^",
    "cross-env": "^10.1.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "^1.56.0",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.4",
    "jiti": "^2.6.1",
    "markdown-it": "^14.1.1",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0",
    "vue": "^3.5.30"
  },
  "lint-staged": {
    "*.{js,ts,vue}": "eslint --cache --fix",
    "*.{js,ts,mts,tsx,vue}": "oxfmt"
  }
}
